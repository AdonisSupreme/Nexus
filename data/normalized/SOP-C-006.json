      "sequence": 2,
      "source_section": "pre mount checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Backup PaymentsFromSTPLink folder",
      "sequence": 3,
      "source_section": "pre mount checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Verify Linux server backup folder is empty",
      "sequence": 4,
      "source_section": "pre mount checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
  "symptoms": [],
  "checks": [],
  "verification_steps": [
    {
      "text": "Check mounts: df -h",
      "sequence": 1,
      "source_section": "post mount validation",
      "atomic": true,
      "safety_critical": false,
      "markers": [
        "command"
      ]
    },
    {
      "text": "Verify all three mounts appear: PaymentsToSTPLink, PaymentsFromSTPLink, EwalletProd",
      "sequence": 2,
      "source_section": "post mount validation",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Test file accessibility",
      "sequence": 3,
      "source_section": "post mount validation",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Verify file transfer functionality",
      "sequence": 4,
      "source_section": "post mount validation",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
  "actions": [
    {
      "text": "Navigate to folder: cd /home/administrator/batch-files/rtgs/outward/toTrustLink",
      "sequence": 1,
      "source_section": "payments to stp procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Check backup folder: ls -1 /home/administrator/batch-files/rtgs/outward/backup | wc -l",
      "sequence": 2,
      "source_section": "payments to stp procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "If count not 0, delete files: rm backup/*",
      "sequence": 3,
      "source_section": "payments to stp procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "Move existing files to backup: mv toTrustLink/*.txt backup/",
      "sequence": 4,
      "source_section": "payments to stp procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Mount outward folder: sudo mount -t cifs //192.168.0.45/PaymentsToSTPLink /home/administrator/batch-files/rtgs/outward/toTrustLink -o username=RTGS,password=*******",
      "sequence": 5,
      "source_section": "payments to stp procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "ip_address"
      ]
    },
    {
      "text": "If no files in toTrustLink, restore from backup: mv backup/* toTrustLink/",
      "sequence": 6,
      "source_section": "payments to stp procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Mount inward folder: sudo mount -t cifs //192.168.0.45/PaymentsFromSTPLink /home/administrator/batch-files/rtgs/inward/idc -o username=RTGS,password=*******",
      "sequence": 7,
      "source_section": "payments from stp procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "ip_address"
      ]
    },
    {
      "text": "Mount ewallet folder: sudo mount -t cifs //192.168.0.45/EwalletProd /home/administrator/batch-files/rtgs/inward/digipay/ -o username=RTGS,password=*******",
      "sequence": 8,
      "source_section": "ewallet mount procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "ip_address"
      ]
    }
  ],
