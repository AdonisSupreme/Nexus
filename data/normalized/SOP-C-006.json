  "preconditions": [
    {
      "text": "Login to server 192.168.0.45",
      "sequence": 1,
      "source_section": "pre mount checks",
      "atomic": true,
      "safety_critical": false,
      "markers": [
        "ip_address"
      ]
    },
    {
