  "actions": [
    {
      "text": "IDC Servers: Check server space: df -h",
      "sequence": 1,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "command"
      ]
    },
    {
      "text": "IDC Servers: Locate logs in /rpool1",
      "sequence": 2,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "IDC Servers: Compress old logs and write to tape drive before deletion",
      "sequence": 3,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "IDC Servers: Monitor log growth patterns",
      "sequence": 4,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "IDC Servers: Schedule regular log rotation",
      "sequence": 5,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Mobile Banking Servers (0.249, 0.62): Check space: du -sh * and df -h",
      "sequence": 6,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "command"
      ]
    },
    {
      "text": "Mobile Banking Servers (0.249, 0.62): Stop PostgreSQL service",
      "sequence": 7,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Mobile Banking Servers (0.249, 0.62): Delete nohup.out files in /srv and /root",
      "sequence": 8,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "Mobile Banking Servers (0.249, 0.62): Set log retention periods: Notification service: /srv/afc/txn-messenger/txn-notification-service/etc/logback.xml (maxHistory 3 days)",
      "sequence": 9,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Mobile Banking Servers (0.249, 0.62): Set log retention periods: Vendor service: /srv/afc/txn-vendor/txn-vendor-service/etc/logback.xml (maxHistory 3 days)",
      "sequence": 10,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Mobile Banking Servers (0.249, 0.62): Restart services",
      "sequence": 11,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Mobile Banking Servers (0.249, 0.62): Verify automatic log maintenance",
      "sequence": 12,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Internet Banking Servers: Check audit log paths",
      "sequence": 13,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Internet Banking Servers: Move logs to tape drive (DBA responsibility)",
      "sequence": 14,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Internet Banking Servers: Ensure logs are written to tape before clearing",
      "sequence": 15,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Internet Banking Servers: Verify space restoration",
      "sequence": 16,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Never delete logs without backup verification",
      "sequence": 17,
      "source_section": "risk mitigation",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "Maintain minimum 3 days of logs for troubleshooting",
      "sequence": 18,
      "source_section": "risk mitigation",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Coordinate with DBA for tape backup verification",
      "sequence": 19,
      "source_section": "risk mitigation",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Monitor space trends for proactive management",
      "sequence": 20,
      "source_section": "risk mitigation",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
