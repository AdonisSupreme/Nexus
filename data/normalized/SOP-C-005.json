      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Open in Notepad, copy data, and paste into Trustlink file (comma separated)",
      "sequence": 15,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
