      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Modify downloaded reports with columns: Column 1: Branch (enter 1000), Column 2: Digipay account number, Column 3: Product code (USD: 150, ZWG: 151), Column 4: Account number, Column 5: Currency (USD or ZWG)",
      "sequence": 13,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
