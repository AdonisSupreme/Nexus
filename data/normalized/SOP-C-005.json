      "safety_critical": false,
      "markers": []
    },
    {
      "text": "For USD Report: Scheme: 2001001 DIGIPAY, Account Status: Active, From Date: 1 Jan 2022; To Date: Current date, Inputter and Authoriser: All, Download report",
      "sequence": 11,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
