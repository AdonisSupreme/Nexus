      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Administrator recovery: Navigate to 'C:\\ProgramData\\Infor\\SunSystems\\Security'",
      "sequence": 28,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Administrator recovery: Open file: Global.Config",
      "sequence": 29,
