      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Administrator recovery: Modify setting from '<serveradminaccess>0</serveradminaccess>' to '<serveradminaccess>1</serveradminaccess>'",
      "sequence": 30,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Administrator recovery: Save file",
      "sequence": 31,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Administrator recovery: Restart service: SunSystems Security Service",
      "sequence": 32,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Administrator recovery: Open user manager without login",
