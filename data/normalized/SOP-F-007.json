    {
      "text": "Access levels Normal User capabilities: View own details only",
      "sequence": 1,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Access levels Administrator capabilities: Add users, edit users, view all users, copy users, delete users",
      "sequence": 2,
      "source_section": "recommended actions",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "Group membership requirement: Admin access requires SunSystems Administrator group",
      "sequence": 3,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation: Login as administrator",
      "sequence": 4,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation: Navigate to 'Security Users (SEU)'",
      "sequence": 5,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation: Click create_user",
      "sequence": 6,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation configure General tab: username: logon_name, full_name: complete_name, description: job_title_or_department, title: position, preferred_language: ui_language, email_address: user_email, photo: optional",
      "sequence": 7,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation: Assign user groups",
      "sequence": 8,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation configure Operator settings: operator_code: three_characters, default_business_unit, default_ledger, language, temporary_work_folder, default_transaction_date",
      "sequence": 9,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation configure Authentication: standard_authentication enabled: true, password_required: true, windows_authentication: optional, directory_service_authentication: optional",
      "sequence": 10,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation configure Authorization: enabled: true, authorization_password_required: true",
      "sequence": 11,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "User creation: Save user",
      "sequence": 12,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
