      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Navigate through Veeam interface",
      "sequence": 3,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Home tab → Restore → VMware",
      "sequence": 4,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Select Instant VM Recovery → Next",
      "sequence": 5,
      "source_section": "recommended actions",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "Expand Server 120 Working → Select NewAgriLiveCore → Next",
      "sequence": 6,
      "source_section": "recommended actions",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "Select restore point (latest increment) → Next",
      "sequence": 7,
      "source_section": "recommended actions",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "Recovery Mode: Restore to new location or different settings → Next",
      "sequence": 8,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Destination: Change restored VM name → Next",
      "sequence": 9,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
