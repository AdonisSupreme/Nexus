  "actions": [
    {
      "text": "PaymentsToSTPLink Mount: backup PaymentsToSTPLink folder on server 0.45 (compress/rename)",
      "sequence": 1,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "PaymentsToSTPLink Mount: SSH to server 192.168.0.249",
      "sequence": 2,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "command",
        "ip_address"
      ]
    },
    {
      "text": "PaymentsToSTPLink Mount: Navigate: cd /home/administrator/batch-files/rtgs/outward",
      "sequence": 3,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "PaymentsToSTPLink Mount: Check backup folder: ls -1 backup/ | wc -l",
      "sequence": 4,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "PaymentsToSTPLink Mount: If count not 0, delete files: rm backup/*",
      "sequence": 5,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "sql"
      ]
    },
    {
      "text": "PaymentsToSTPLink Mount: Move files to backup: mv toTrustLink/*.txt backup/",
      "sequence": 6,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "PaymentsToSTPLink Mount: Mount outward folder: sudo mount -t cifs //192.168.0.45/PaymentsToSTPLink /home/administrator/batch-files/rtgs/outward/toTrustLink -o username=RTGS,password=*******",
      "sequence": 7,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "ip_address"
      ]
    },
    {
      "text": "PaymentsToSTPLink Mount: If no files in toTrustLink, move from backup: mv backup/* toTrustLink/",
      "sequence": 8,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "PaymentsFromSTPLink Mount: backup PaymentsFromSTPLink folder on server 0.45",
      "sequence": 9,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "PaymentsFromSTPLink Mount: Mount inward folder: sudo mount -t cifs //192.168.0.45/PaymentsFromSTPLink /home/administrator/batch-files/rtgs/inward/idc -o username=RTGS,password=*******",
      "sequence": 10,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "ip_address"
      ]
    },
    {
      "text": "Ewallet Mount: Mount Ewallet folder: sudo mount -t cifs //192.168.0.45/EwalletProd /home/administrator/batch-files/rtgs/inward/digipay/ -o username=RTGS,password=*******",
      "sequence": 11,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "ip_address"
      ]
    }
  ],
