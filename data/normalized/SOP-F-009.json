      "source_section": "notes",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Regular CAB meetings for standard changes",
      "sequence": 3,
      "source_section": "notes",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Change windows scheduled to minimize business impact",
      "sequence": 4,
      "source_section": "notes",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Comprehensive testing required before production implementation",
