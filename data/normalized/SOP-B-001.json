      "safety_critical": true,
      "markers": [
        "command"
      ]
    },
    {
      "text": "If process still running, kill it: kill -9 <PID> (PID is first number)",
      "sequence": 5,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Start the service: ./startIDC.sh",
      "sequence": 6,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Monitor logs: tail -f /rpool1/core/jboss-eap-7.4/standalone/log",
      "sequence": 7,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "command"
      ]
