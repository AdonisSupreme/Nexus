  "preconditions": [],
  "symptoms": [
    {
      "text": "eod process does not initiate at scheduled time",
      "sequence": 1,
      "source_section": "symptoms",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "eod jobs display \"failed\" or \"stuck\" status",
      "sequence": 2,
      "source_section": "symptoms",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "branches are unable to sign off",
      "sequence": 3,
      "source_section": "symptoms",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "system business date does not advance after eod",
      "sequence": 4,
      "source_section": "symptoms",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "end-of-day reports not generated",
      "sequence": 5,
      "source_section": "symptoms",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
  "checks": [
    {
      "text": "verify all branches have signed out using the qbrnstatus menu",
      "sequence": 1,
      "source_section": "checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "check for unauthorized non-financial transactions using the acmn menu",
      "sequence": 2,
      "source_section": "checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "confirm there are no pending financial transactions per branch",
      "sequence": 3,
      "source_section": "checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "review eod and sod exception logs for errors",
      "sequence": 4,
      "source_section": "checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "verify that treasury eod completed successfully before idc eod",
      "sequence": 5,
      "source_section": "checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "check loan management system (lms) job status",
      "sequence": 6,
      "source_section": "checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "verify database locks or constraints affecting eod processing",
      "sequence": 7,
      "source_section": "checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
  "verification_steps": [],
  "actions": [
    {
      "text": "contact affected branches and request immediate sign-off if still active.",
      "sequence": 1,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": true,
      "markers": []
    },
    {
      "text": "reject or resolve unauthorized non-financial transactions.",
      "sequence": 2,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": true,
      "markers": []
    },
    {
      "text": "escalate pending financial transactions to respective branch managers.",
      "sequence": 3,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": true,
      "markers": []
    },
    {
      "text": "confirm treasury eod completion status before proceeding.",
      "sequence": 4,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": true,
      "markers": []
    },
    {
      "text": "review exception logs to identify the exact failing component or job.",
      "sequence": 5,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": true,
      "markers": []
    },
    {
      "text": "escalate to idc support team if the issue cannot be resolved at first level.",
      "sequence": 6,
      "source_section": "recommended actions",
      "atomic": false,
      "safety_critical": true,
      "markers": []
    }
  ],
  "rollback": [
    {
      "text": "none (incident response guidance only)",
      "sequence": 1,
      "source_section": "rollback",
      "atomic": false,
      "safety_critical": true,
      "markers": []
    }
  ],
  "escalation": [],
  "notes": [
