      "sequence": 1,
      "source_section": "pre checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "check no Treasury transactions in progress",
      "sequence": 2,
      "source_section": "pre checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "confirm with Treasury department",
      "sequence": 3,
      "source_section": "pre checks",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
  "symptoms": [],
  "checks": [],
  "verification_steps": [
    {
      "text": "verify Treasury interface connectivity",
      "sequence": 1,
      "source_section": "post verification",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "test Treasury transactions",
      "sequence": 2,
      "source_section": "post verification",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "check interface logs for errors",
      "sequence": 3,
      "source_section": "post verification",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
  "actions": [
    {
      "text": "SSH to server 192.168.1.110 or 192.168.1.111",
      "sequence": 1,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "command",
        "ip_address"
      ]
    },
    {
      "text": "Find the process ID: ps -ef | grep \"ORBIConfig.prop\"",
      "sequence": 2,
      "source_section": "procedure",
      "atomic": true,
      "safety_critical": true,
      "markers": [
        "command"
      ]
    },
    {
      "text": "Kill the process: kill -9 <PID> (PID is first number)",
      "sequence": 3,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Navigate to directory: cd /rpool1/TRY/jboss-eap-7.4/standalone/log",
      "sequence": 4,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Start JBOSS: nohup ./standalone.sh &",
      "sequence": 5,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    },
    {
      "text": "Repeat on second server",
      "sequence": 6,
      "source_section": "procedure",
      "atomic": false,
      "safety_critical": false,
      "markers": []
    }
  ],
  "rollback": [
    {
      "text": "if interface fails to start, check ORBIConfig properties",
      "sequence": 1,
      "source_section": "rollback",
      "atomic": false,
      "safety_critical": false,
